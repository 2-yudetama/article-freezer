// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  user_id             String   @id @default(uuid()) @db.Uuid
  provider            String   @db.Text
  provider_account_id String   @db.Text
  name                String   @db.Text
  email               String   @db.Text
  image               String   @db.Text
  role                Int      @default(0) @db.Integer
  created_at          DateTime @default(now()) @db.Timestamp()
  updated_at          DateTime @updatedAt @db.Timestamp()

  articles         Article[]
  article_comments ArticleComment[]
  article_tags     ArticleTag[]

  @@unique([provider, provider_account_id])
  @@index([role])
  @@map("users")
}

model Article {
  article_id     String   @id @default(uuid()) @db.Uuid
  user_id        String   @db.Uuid
  title          String   @db.Text
  published_date String   @db.VarChar(255)
  content        String   @db.Text
  is_favorite    Boolean  @default(false)
  created_at     DateTime @default(now()) @db.Timestamp()
  updated_at     DateTime @updatedAt @db.Timestamp()

  user          User                  @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  comment       ArticleComment?
  article_tags  ArticleTagOnArticle[]
  articleSource ArticleSource?

  @@index([user_id])
  @@map("articles")
}

/**
 * ソースの種類が増える際はテーブル分割を推奨
 */
model ArticleSource {
  article_id String   @id @db.Uuid
  type       String   @db.VarChar(255)
  url        String   @db.Text
  created_at DateTime @default(now()) @db.Timestamp()
  updated_at DateTime @updatedAt @db.Timestamp()

  article Article @relation(fields: [article_id], references: [article_id], onDelete: Cascade)

  @@index([type])
  @@map("article_sources")
}

model ArticleComment {
  comment_id String   @id @default(uuid()) @db.Uuid
  article_id String   @unique @db.Uuid
  user_id    String   @db.Uuid
  comment    String   @db.Text
  created_at DateTime @default(now()) @db.Timestamp()
  updated_at DateTime @updatedAt @db.Timestamp()

  article Article @relation(fields: [article_id], references: [article_id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id])
  @@map("article_comments")
}

model ArticleTag {
  tag_id      String   @id @default(uuid()) @db.Uuid
  user_id     String   @db.Uuid
  name        String   @db.VarChar(255)
  color       String   @db.VarChar(7)
  description String   @db.VarChar(255)
  created_at  DateTime @default(now()) @db.Timestamp()
  updated_at  DateTime @updatedAt @db.Timestamp()

  user         User                  @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  article_tags ArticleTagOnArticle[]

  @@unique([user_id, name])
  @@index([user_id])
  @@map("article_tags")
}

model ArticleTagOnArticle {
  article_id String @db.Uuid
  tag_id     String @db.Uuid

  article Article    @relation(fields: [article_id], references: [article_id], onDelete: Cascade)
  tag     ArticleTag @relation(fields: [tag_id], references: [tag_id], onDelete: Cascade)

  @@id([article_id, tag_id])
  @@index([tag_id])
  @@map("article_tags_articles")
}
